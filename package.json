{
  "name": "catalogo-streaming",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "description": "API catalogo streaming — starter CI-ready per i lab di automazione (Modulo 5)",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "dependencies": { "express": "5.2.1" },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.6",
    "@types/node": "26.0.0",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "fast-check": "4.8.0",
    "@fast-check/vitest": "0.4.1",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": { "node": ">=22" }
}
