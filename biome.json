{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": { "includes": ["**/src/**/*.ts", "**/e2e/**/*.ts"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noConsole": "off" },
      "correctness": { "noUnusedPrivateClassMembers": "off" }
    }
  }
}
